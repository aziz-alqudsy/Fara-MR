# ======== DISCORD CONFIGURATION ========
# Discord Bot Token - Dapatkan dari https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Channel ID - ID channel tempat notifikasi PR akan dikirim
DISCORD_CHANNEL_ID=your_channel_id_here

# Discord Role ID - ID role untuk mention role (opsional)
# DISCORD_ROLE_ID=your_role_id_here

# ======== TELEGRAM CONFIGURATION ========
# Telegram Bot Token - Dapatkan dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID - ID grup/channel Telegram (contoh: -1001234567890)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Telegram Thread ID - ID topic/thread di grup (opsional, untuk posting ke topic tertentu)
# TELEGRAM_THREAD_ID=your_thread_id_here

# ======== SERVER CONFIGURATION ========
# Port untuk webhook server
PORT=3000
